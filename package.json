{
  "name": "stocktek",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first stock market watchlist analysis assistant.",
  "scripts": {
    "install:all": "pip install -r backend/requirements.txt && cd frontend && npm install",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev -- --host 127.0.0.1",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "build": "cd frontend && npm run build",
    "test": "cd backend && pytest"
  },
  "engines": {
    "node": ">=20"
  }
}

