# Backend
STOCKTEK_DB_PATH=data/stocktek.duckdb
# SEC requires a real contact in the user agent (https://www.sec.gov/os/accessing-edgar-data)
STOCKTEK_SEC_USER_AGENT=StockTek/0.1 educational research your-email@example.com

# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Free API key from https://www.tiingo.com (Account -> API Token)
TIINGO_API_KEY=

# Free API key from https://finnhub.io (Dashboard -> API Keys)
FINNHUB_API_KEY=

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
